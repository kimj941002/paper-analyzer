# Anthropic API Key
# https://console.anthropic.com/settings/keys 에서 발급
# 이 파일을 .env로 복사한 뒤 실제 키를 입력하세요:
#   cp .env.example .env
ANTHROPIC_API_KEY=sk-ant-api03-여기에_실제_키_입력

# Google Drive 저장 (선택 — 미설정 시 비활성)
# JSON 키 파일 내용을 한 줄로 붙여넣기 (경로가 아닌 내용 자체)
# GDRIVE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# GDRIVE_FOLDER_ID=루트_폴더_ID
# GDRIVE_SHEET_ID=인덱스_Sheets_ID
