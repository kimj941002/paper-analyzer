# =============================================
# Streamlit Cloud Secrets 설정 예시
# =============================================
# 이 파일은 예시입니다. 실제 값은:
#   - 로컬: .streamlit/secrets.toml 에 복사 후 입력
#   - Streamlit Cloud: 앱 대시보드 → Settings → Secrets 에 입력
# =============================================

# 필수: Anthropic API Key
ANTHROPIC_API_KEY = "sk-ant-api03-여기에_실제_키_입력"

# 선택: Google Drive 저장 기능
# 1) Service Account JSON 키 내용 (한 줄, 따옴표로 감싸기)
GDRIVE_CREDENTIALS_JSON = '{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# 2) Google Drive 루트 폴더 ID (URL에서 추출: drive.google.com/drive/folders/여기가_ID)
GDRIVE_FOLDER_ID = "여기에_Drive_폴더_ID"

# 3) Google Sheets 인덱스 문서 ID (URL에서 추출: docs.google.com/spreadsheets/d/여기가_ID)
GDRIVE_SHEET_ID = "여기에_Sheets_ID"
